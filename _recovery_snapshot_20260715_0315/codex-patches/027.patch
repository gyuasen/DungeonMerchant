+        int rawDamage = Round(
+            (attacker.Attack * attackPower +
+             attacker.MaxMagicPower * magicPower) *
+            (critical ? context.CriticalDamageMultiplier : 1f));
+        int before = target.CurrentHP;
+        target.TakeDamage(rawDamage);
+        int damage = before - target.CurrentHP;
